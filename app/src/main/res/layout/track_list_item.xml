<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:theme="@style/Theme.PlaylistMaker"
    android:id="@+id/track_list_item"
    android:layout_width="match_parent"
    android:layout_height="61dp"
    android:orientation="horizontal"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="61dp"
        android:orientation="horizontal"
        android:background="@color/recyclerViewBackgroundColor"
        >
        <androidx.cardview.widget.CardView
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="13dp"
            android:layout_gravity="center_vertical"
            app:cardCornerRadius="2dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardElevation="0dp"
            app:cardUseCompatPadding="false">

            <ImageView
                android:id="@+id/album_cover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="33dp"
            android:orientation="vertical"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:layout_marginStart="8dp">

            <TextView
                style="@style/TrackListTextAttributes"
                android:id="@+id/song_title"
                android:layout_width="wrap_content"
                android:layout_height="16sp"
                android:text="@string/song_title_draft"
                android:textSize="@dimen/tracklist_song_title_text_size"
                android:textColor="@color/colorOnSurface"
                android:ellipsize="end"
                android:maxLines="1"
                >
            </TextView>

            <TextView
                style="@style/TrackListTextAttributes"
                android:id="@+id/song_artist_and_time"
                android:layout_width="wrap_content"
                android:layout_height="13sp"
                android:text="@string/Song_artist_and_time_draft"
                android:textSize="@dimen/tracklist_artist_and_time_text_size"
                android:textColor="@color/colorOnSurfaceVariant"
                >
            </TextView>
        </LinearLayout>
        <ImageView
            style="@style/ItemIcon"
            android:id="@+id/item_icon_forward"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/arrow_forward"
            android:layout_gravity="center_vertical">
        </ImageView>
    </LinearLayout>

</androidx.cardview.widget.CardView>