<?xml version="1.0" encoding="utf-8"?>
<resources>

<style name="MainScreenToolbarTitleStyle" parent="Theme.MaterialComponents.DayNight.NoActionBar">
    <item name="android:fontFamily">@font/yandexsansdisplaybold</item>
    <item name="android:textSize">@dimen/toolbar_title_text_size</item>
    <item name="android:textColor">@color/white</item>
</style>

    <style name="SettingsScreenToolbarTitleStyle" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:fontFamily">@font/yandexsansdisplaybold</item>
        <item name="android:textSize">@dimen/toolbar_title_text_size</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="MainScreenButtonsStyle" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:backgroundTint">@color/white</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">@dimen/main_screen_item_text_size</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">@dimen/main_screen_text_icon_padding</item>
        <item name="iconSize">@dimen/main_screen_button_icon_size</item>
        <item name="iconTint">@color/black</item>
    </style>



        <!-- Стиль для контейнера пункта настроек -->
        <style name="SettingsItemContainer">
            <item name="android:layout_width">match_parent</item>
            <item name="android:layout_height">@dimen/settings_screen_item_height</item>
            <item name="android:orientation">horizontal</item>
            <item name="android:gravity">center_vertical</item>
            <item name="android:paddingStart">16dp</item>
            <item name="android:paddingEnd">16dp</item>
        </style>

        <!-- Стиль для текста в пункте настроек -->
        <style name="SettingsItemText">
            <item name="android:layout_width">0dp</item>
            <item name="android:layout_height">wrap_content</item>
            <item name="android:textSize">@dimen/settings_screen_item_text_size</item>
            <item name="android:layout_weight">1</item>
        </style>

        <!-- Стиль для иконки в пункте настроек -->
        <style name="SettingsItemIcon">
            <item name="android:layout_width">24dp</item>
            <item name="android:layout_height">24dp</item>
            <item name="android:layout_marginEnd">12dp</item>
            <item name="android:backgroundTint">@color/white</item>
        </style>

        <!-- Стиль для тулбара экрана настроек -->
        <style name="SettingsToolbar">
            <item name="android:layout_width">match_parent</item>
            <item name="android:layout_height">56dp</item>
            <item name="android:layout_marginBottom">24dp</item>
            <item name="titleTextAppearance">@style/SettingsScreenToolbarTitleStyle</item>
        </style>

        <!-- Стиль для переключателя -->
        <style name="SettingsSwitch">
            <item name="android:layout_width">wrap_content</item>
            <item name="android:layout_height">wrap_content</item>
            <item name="android:layout_marginEnd">10dp</item>
        </style>




</resources>