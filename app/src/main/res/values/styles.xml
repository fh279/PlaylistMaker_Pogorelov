<?xml version="1.0" encoding="utf-8"?>
<resources>

<style name="MainAndSettingsScreenCommonAttributes">
    <item name="android:orientation">vertical</item>
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">match_parent</item>

</style>

    <style name="MainScreenToolbarTitleStyle">
    <item name="android:fontFamily">@font/ys_display_medium</item>
    <item name="android:textSize">@dimen/toolbar_title_text_size</item>
    <item name="android:layout_width">match_parent</item>
    <item name="android:backgroundTint">?attr/colorPrimary</item>
    <item name="titleTextColor">?attr/colorOnPrimary</item>
</style>

    <style name="SettingsScreenToolbarTitleStyle">
        <item name="android:fontFamily">@font/ys_display_bold</item>
        <item name="android:textSize">@dimen/toolbar_title_text_size</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="MainScreenButtonsStyle" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_weight">1</item>
        <item name="android:backgroundTint">?attr/colorOnPrimary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">@dimen/main_screen_item_text_size</item>
        <item name="android:font">@font/ys_display_medium</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">@dimen/main_screen_text_icon_padding</item>
        <item name="iconSize">@dimen/main_screen_button_icon_size</item>
        <item name="iconTint">?attr/colorOnSurface</item>
    </style>

    <style name="SettingsItemContainer">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/settings_screen_item_height</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <style name="SettingsItemText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/item_text_size_common</item>
        <item name="android:layout_weight">1</item>
        <item name="android:font">@font/ys_display_regular</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="ItemIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:layout_marginEnd">12dp</item>
        <item name="android:backgroundTint">?attr/colorOnSurfaceVariant</item>
        <item name="tint">@color/colorOnSurfaceVariant</item>
    </style>

    <style name="SettingsToolbar">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_marginBottom">24dp</item>
        <item name="titleTextAppearance">@style/SettingsScreenToolbarTitleStyle</item>
        <item name="font">@font/ys_display_medium</item>
    </style>

    <style name="SearchToolbar">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="titleTextAppearance">@style/SearchScreenToolbarTitleStyle</item>
        <item name="font">@font/ys_display_medium</item>
    </style>

    <style name="SearchScreenToolbarTitleStyle">
        <item name="android:fontFamily">@font/ys_display_bold</item>
        <item name="android:textSize">@dimen/toolbar_title_text_size</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:backgroundTint">?attr/colorOnSurface</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="SettingsSwitch">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">10dp</item>
    </style>

    <style name="TrackListTextAttributes">
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
    </style>style>
</resources>